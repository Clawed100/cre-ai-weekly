# ========== REQUIRED CONFIGURATION ==========

# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Create a product + price in Stripe Dashboard:
# 1. Go to https://dashboard.stripe.com/products
# 2. Click "+ Add product"
# 3. Name: "CRE + AI Weekly Pro"
# 4. Price: $12.00 / month (recurring)
# 5. Copy the price ID below (starts with price_)
STRIPE_PRICE_ID=price_...

# Get from https://resend.com/api-keys
RESEND_API_KEY=re_...

# Password for the admin dashboard (use a strong random string, minimum 16 characters)
# Generate with: openssl rand -base64 32
ADMIN_PASSWORD=your-strong-password-here

# Secret for unsubscribe token generation (separate from admin password)
# Recommended: use ADMIN_PASSWORD or generate another strong string
UNSUBSCRIBE_SECRET=unsubscribe-secret-here

# Your verified sending email (must match domain verified in Resend)
FROM_EMAIL=jeff@yourdomain.com

# Your site URL (for unsubscribe links and redirects)
SITE_URL=https://yourdomain.com

# Stripe Webhook Secret (from Stripe Dashboard > Developers > Webhooks)
# Create a webhook endpoint pointing to https://yourdomain.com/api/webhook
# Listen for: checkout.session.completed, customer.subscription.deleted, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# CAN-SPAM compliant mailing address (shown in email footers)
MAILING_ADDRESS=CRE + AI Weekly · 123 Main Street · Suite 100 · New York, NY 10001

# ========== OPTIONAL CONFIGURATION ==========

# Turnstile (Cloudflare) for CAPTCHA protection
# Get from https://dash.cloudflare.com/
# TURNSTILE_SECRET=your_turnstile_secret

# ========== NOTES ==========
# - Store this file securely and never commit it to version control
# - All required fields must be set for the application to function
# - Keep ADMIN_PASSWORD and UNSUBSCRIBE_SECRET secure and change them regularly
# - Verify all email addresses are configured in Resend before sending
