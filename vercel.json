{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "robots.txt",
      "use": "@vercel/static"
    },
    {
      "src": "sitemap.xml",
      "use": "@vercel/static"
    },
    {
      "src": "og-image.png",
      "use": "@vercel/static"
    },
    {
      "src": "404.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/og-image.png",
      "dest": "/og-image.png",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt",
      "headers": {
        "Content-Type": "text/plain"
      }
    },
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml",
      "headers": {
        "Content-Type": "application/xml",
        "Cache-Control": "public, max-age=86400"
      }
    },
    { "src": "/api/health", "dest": "/api/health.js" },
    { "src": "/api/webhook", "dest": "/api/webhook.js" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    {
      "src": "/(.*\\.html)$",
      "dest": "/$1",
      "headers": {
        "Cache-Control": "public, max-age=0, must-revalidate"
      }
    },
    {
      "src": "/success.html",
      "dest": "/success.html",
      "headers": {
        "Cache-Control": "public, max-age=0, must-revalidate"
      }
    },
    {
      "src": "/admin.html",
      "dest": "/admin.html",
      "headers": {
        "Cache-Control": "public, max-age=0, must-revalidate",
        "X-Robots-Tag": "noindex, nofollow"
      }
    },
    {
      "src": "/unsubscribe.html",
      "dest": "/unsubscribe.html",
      "headers": {
        "Cache-Control": "public, max-age=0, must-revalidate"
      }
    },
    {
      "src": "/404",
      "dest": "/404.html",
      "status": 404
    },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "functions": {
    "api/send-newsletter.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/subscribers.js": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/subscribe.js": {
      "maxDuration": 10,
      "memory": 512
    },
    "api/create-checkout.js": {
      "maxDuration": 10,
      "memory": 512
    },
    "api/webhook.js": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/verify-session.js": {
      "maxDuration": 10,
      "memory": 512
    },
    "api/preview-email.js": {
      "maxDuration": 10,
      "memory": 512
    },
    "api/unsubscribe.js": {
      "maxDuration": 10,
      "memory": 512
    },
    "api/health.js": {
      "maxDuration": 10,
      "memory": 256
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
